# HandwriteAI Environment Configuration
# Copy this file to .env and fill in your values

# Flask settings
FLASK_ENV=development
FLASK_DEBUG=false
PORT=5000

# Tesseract path (Windows users — set this to your tesseract.exe path)
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# EasyOCR languages (comma-separated ISO codes)
EASYOCR_LANGUAGES=en

# Enable TrOCR (slow first-time download, best for handwriting)
TROCR_ENABLED=false

# Max upload size in MB
MAX_UPLOAD_MB=16


TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# Database
DATABASE_URI=sqlite:///ocr_database.db
